# ── 이 파일을 복사하여 .env.local 을 만드세요 ──
# cp .env.example .env.local

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API 서버 주소
# 로컬 개발:    http://localhost:8080
# Docker Compose: http://backend:8080
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_API_URL=http://localhost:8080

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Supabase Realtime (채팅 기능) — Auth 아님
# Supabase → Settings → API
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # anon public key (공개 가능)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI API (서버 전용 — 브라우저에 노출되지 않음)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Gemini (필수) — 의료 대본 생성 + 실시간 메모 파싱
# 발급: https://aistudio.google.com → Get API key (무료)
GEMINI_API_KEY=

# Groq (선택, Gemini 실패 시 폴백)
# 발급: https://console.groq.com (무료)
GROQ_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Kakao OAuth2 (소셜 로그인)
# 발급: https://developers.kakao.com → 내 애플리케이션 → REST API 키
# 리다이렉트 URI는 카카오 콘솔의 "카카오 로그인 > Redirect URI" 와 동일해야 함
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_KAKAO_REST_API_KEY=   # REST API 키 (브라우저에서 직접 Kakao 인증 URL 구성에 사용)
# redirect_uri는 코드에서 window.location.origin으로 자동 구성되므로 설정 불필요

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 공공데이터 API — 건강보험심사평가원 (서버 전용)
# 병원정보서비스 + 질병정보서비스 동일 키 사용
# 발급: https://www.data.go.kr → 건강보험심사평가원 API 신청 (무료)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HIRA_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# UT (유저 테스트) 전용 계정 — 서버 사이드 전용
# /ut?role=patient        → 이주민 UT 계정 자동 로그인
# /ut?role=interpreter    → 통번역가 UT 계정 자동 로그인
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
UT_PATIENT_EMAIL=
UT_PATIENT_PASSWORD=
UT_INTERPRETER_EMAIL=
UT_INTERPRETER_PASSWORD=
NEXT_PUBLIC_RRWEB_PUBLIC_KEY=   # rrweb Cloud public key (브라우저 노출 가능, write-only)
