# ── 이 파일을 복사하여 .env.local 을 만드세요 ──
# cp .env.example .env.local

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API 서버 주소
# 로컬 개발:    http://localhost:8080
# Docker Compose: http://backend:8080
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_API_URL=http://localhost:8080

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Supabase Realtime (채팅 기능) — Auth 아님
# Supabase → Settings → API
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # anon public key (공개 가능)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI API (서버 전용 — 브라우저에 노출되지 않음)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Gemini (필수) — 의료 대본 생성 + 실시간 메모 파싱
# 발급: https://aistudio.google.com → Get API key (무료)
GEMINI_API_KEY=

# Groq (선택, Gemini 실패 시 폴백)
# 발급: https://console.groq.com (무료)
GROQ_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 공공데이터 API — 건강보험심사평가원 (서버 전용)
# 병원정보서비스 + 질병정보서비스 동일 키 사용
# 발급: https://www.data.go.kr → 건강보험심사평가원 API 신청 (무료)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HIRA_API_KEY=
