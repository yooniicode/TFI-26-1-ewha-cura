# ── 이 파일을 복사하여 .env.local 을 만들고 실제 값을 채우세요 ──
# cp .env.example .env.local

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PostgreSQL (로컬 Docker)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
POSTGRES_DB=byby
POSTGRES_USER=byby
POSTGRES_PASSWORD=              # 직접 설정 (예: byby123)
DB_PORT=5433                    # 호스트 노출 포트 (컨테이너 내부는 5432)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Spring Boot
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SPRING_PROFILES_ACTIVE=local
BACKEND_PORT=8080
TZ=Asia/Seoul

SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/byby
SPRING_DATASOURCE_USERNAME=byby
SPRING_DATASOURCE_PASSWORD=     # POSTGRES_PASSWORD 와 동일

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# JWT 인증 (Supabase Auth 제거 — 백엔드 자체 JWT)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 생성: openssl rand -base64 64  (256 bit 이상 필수)
JWT_SECRET=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Supabase (DB 전용 — Auth 사용 안 함)
# Supabase PostgreSQL + Realtime(채팅)에만 사용
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=              # Supabase → Settings → API → anon public
# SUPABASE_SERVICE_KEY 는 더 이상 필요하지 않음

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI API
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Gemini (필수) — 의료 대본 생성 + 실시간 메모 파싱
# 발급: https://aistudio.google.com → Get API key (무료)
GEMINI_API_KEY=

# Google Sheets (선택) — 관리자 구글 시트 연동
# 발급: Google Cloud Console → APIs & Services → Credentials → API Key
# 시트는 "링크가 있는 모든 사용자 — 뷰어" 로 공유 설정 필요
GOOGLE_SHEETS_API_KEY=

# Google Sheets Export (선택) — 서비스 계정으로 보고서를 내보낼 센터별 기존 스프레드시트 ID
# 센터마다 빈 시트를 하나씩 만든 뒤 서비스 계정 client_email에 편집 권한으로 공유하고 ID를 매핑하세요.
# 예: GOOGLE_EXPORT_SPREADSHEET_IDS={"센터_UUID":"스프레드시트_ID","센터_UUID2":"스프레드시트_ID2"}
# 또는: GOOGLE_EXPORT_SPREADSHEET_IDS=센터_UUID=스프레드시트_ID,센터_UUID2=스프레드시트_ID2
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_EXPORT_SPREADSHEET_IDS=
GOOGLE_EXPORT_SPREADSHEET_ID=   # 로컬 테스트용 단일 파일 fallback

# Groq (선택, Gemini 실패 시 폴백)
# 발급: https://console.groq.com (무료)
GROQ_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 공공데이터 API (건강보험심사평가원)
# 병원정보서비스 + 질병정보서비스 동일 키 사용
# 발급: https://www.data.go.kr → 건강보험심사평가원 API 신청
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HIRA_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Frontend
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://backend:8080

# Supabase Realtime (채팅) — Auth와 무관, anon key는 공개 가능
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # anon key (공개 가능)

# Kakao OAuth2 (프론트엔드 — 로그인/연동 버튼, 아래 KAKAO_REST_API_KEY와 동일한 값)
# 빌드 시점에 클라이언트 번들에 포함되므로 값 변경 후 `docker compose build frontend` 재실행 필요
NEXT_PUBLIC_KAKAO_REST_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CORS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
BYBY_SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:3000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 관리자 시크릿 코드
# 센터 담당자 계정 생성: POST /api/v1/auth/register-admin { secretCode: 이 값 }
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ADMIN_BOOTSTRAP_CODE=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 개발자 전용 센터 등록/수정 시크릿
# Swagger → Centers → POST /centers/dev, PUT /centers/dev/{id}
# body 의 devSecret 필드에 이 값을 입력해야 합니다
# 미설정 시 dev API 비활성화 (403 반환)
# 운영에서는 충분히 강한 값으로 설정하세요
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CENTER_DEV_SECRET=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Kakao OAuth2 (백엔드 — 토큰 교환에 사용)
# 발급: https://developers.kakao.com → 내 애플리케이션 → REST API 키
# 같은 값을 위쪽 Frontend 섹션의 NEXT_PUBLIC_KAKAO_REST_API_KEY 에도 설정해야 함
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Swagger UI 접근 비밀번호
# 미설정 시 인증 없이 접근 (로컬 개발용)
# 운영 시 설정 → 사용자명: swagger / 비밀번호: 이 값
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SWAGGER_SECRET=
